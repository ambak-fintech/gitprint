{
  "version": 1,
  "hooks": {
    "sessionEnd": [
      {
        "type": "command",
        "bash": ".github/hooks/gitprint-copilot-stop.sh",
        "timeoutSec": 30
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": ".github/hooks/gitprint-copilot-post-tool.sh",
        "timeoutSec": 10
      }
    ]
  }
}